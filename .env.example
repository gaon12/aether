# Database
SQLITE_DB_PATH=data/aether.db

# Security
# TOKEN_ENCRYPTION_KEY must be exactly 32 characters for AES-256-CBC.
TOKEN_ENCRYPTION_KEY=your_32_chars_long_key_here_123

# If `.env` is missing on first local run, Aether will auto-create it with:
# - SQLITE_DB_PATH=data/aether.db
# - a random 32-character TOKEN_ENCRYPTION_KEY

# Prompt injection blocking threshold (0.0 ~ 1.0, default 0.8)
# Requests with injection score >= this value are blocked before LLM call.
INJECTION_BLOCK_THRESHOLD=0.8

# The settings below are now managed in the web admin after login:
# - Threads App ID / Secret
# - Threads Webhook Verify Token / Secret
# - NEXT_PUBLIC_APP_URL
# - CRON_SECRET
# - OPENAI_BASE_URL / OPENAI_MODEL_NAME / OPENAI_API_KEY / OPENAI_TIMEOUT_MS
# - AETHER_WORKER_ADAPTER_MODULE / AETHER_METRICS_ADAPTER_MODULE
# - WORKER_POLL_INTERVAL_MS / WORKER_HEARTBEAT_INTERVAL_MS / TOKEN_CHECK_INTERVAL_MS
# - THREADS_BOT_HANDLE / MIN_SOURCE_TEXT_CHARACTERS / MAX_SUMMARY_LENGTH
